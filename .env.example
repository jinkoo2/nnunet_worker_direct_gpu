# Dashboard connection
DASHBOARD_URL=https://nnunet-dashboard-1.apps.myphysics.net
DASHBOARD_API_KEY=changeme

# Notifications (optional — leave blank to disable)
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/XXXXXXXXX/messages?key=XXXXXXXXX&token=XXXXXXXXX

# Worker identity (shown in dashboard Workers tab)
WORKER_NAME=worker-gpu01
WORKER_HOSTNAME=gpu01.example.com
GPU_NAME=NVIDIA A100 80GB
GPU_MEMORY_GB=80.0
CPU_CORES=32
SYSTEM_MEMORY_GB=64.0  # system RAM in GB

# Timing
POLL_INTERVAL_S=30
HEARTBEAT_INTERVAL_S=60

# Paths
DATA_DIR=/data/nnunet_trainer_data
CONDA_ENV=nnunet_trainer
CONDA_PROFILE=/opt/miniconda3/etc/profile.d/conda.sh
# SCRIPTS_DIR=  # auto-detected: ./scripts/ next to main.py

# nnUNet settings
DEVICE=cuda
NUM_GPUS=1
NUM_PREPROCESSING_WORKERS=8  # reduce if system memory is limited
